<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= pageTitle %>
    </title>
    <link rel="stylesheet" href="/css/main.css">
</head>

<body class="page-add">
    <header class="app-header">
        <a class="nav-link" href="/">Home</a>
        <a class="nav-link" href="/products">Products</a>
        <a class="nav-link" href="/admin/add-product">Add Product</a>
    </header>
    <main class="app-main">
        <form class="product-form" action="/admin/add-product" method="post">
            <input class="product-input" type="text" name="title" placeholder="Enter product's name">
            <input class="product-input" type="text" name="price" placeholder="Enter product's price">
            <input class="product-input" type="text" name="desc" placeholder="Enter product's description">
            <button class="submit-button" type="submit">
                Submit
            </button>
        </form>
    </main>
</body>

</html>